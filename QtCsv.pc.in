prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: QtCsv
Description: Qt-based CSV processing library
Version: @PROJECT_VERSION@
Requires: Qt6Core
@QTCSV_WIDGETS_PC_REQUIRES@
Libs: -L${libdir} -lQtCsv
Cflags: -I${includedir}